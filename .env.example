# ele environment variables
# Copy to .env and fill in real values before running locally.
# Never commit .env to source control.

# ── Stripe ────────────────────────────────────────────────────────────────
# Get these from your Stripe dashboard: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook secret — from Stripe dashboard > Webhooks > your endpoint
# For local testing: stripe listen --forward-to localhost:8000/billing/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Stripe Price IDs ──────────────────────────────────────────────────────
# Create products and prices in the Stripe dashboard, then paste the price IDs here.
# Creator credit packs (one-time payments)
STRIPE_PRICE_CREATOR_10=price_...
STRIPE_PRICE_CREATOR_50=price_...
STRIPE_PRICE_CREATOR_200=price_...

# Pro monthly subscription (recurring)
STRIPE_PRICE_PRO_MONTHLY=price_...

# ── App ───────────────────────────────────────────────────────────────────
# Public URL of the app — used for Stripe success/cancel redirect URLs
APP_BASE_URL=http://localhost:8000

# Secret key for signed session cookies — use a long random string in production
SESSION_SECRET=replace-with-a-long-random-string

# ── Database ──────────────────────────────────────────────────────────────
# SQLite (default, suitable for local development and small deployments)
DATABASE_URL=sqlite:///./storage/ele.db

# ── Admin ─────────────────────────────────────────────────────────────────
# Optional: set a token to enable the /admin/keys page
# Access via: http://localhost:8000/admin/keys?token=YOUR_TOKEN_HERE
# Leave blank to disable the admin page entirely.
ADMIN_TOKEN=
